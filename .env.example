# Environment Configuration Template for Bara-Kshaar Flask Application
# Copy this file to .env and update the values for your environment

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database URL for SQLAlchemy
# For local development with PostgreSQL:
DATABASE_URL=postgresql://db_12_kshaar_user:Khia3cT2z2SG2ke8CmxPYNlt693xATRu@dpg-d6q9l5ea2pns739sc4bg-a.virginia-postgres.render.com/db_12_kshaar

# For production (Render, Heroku, etc.), this will be set automatically

# =============================================================================
# FLASK CONFIGURATION
# =============================================================================

# Secret key for Flask sessions and security
# Generate a secure random key for production
SECRET_KEY=your-secret-key-here

# =============================================================================
# DEVELOPMENT SETTINGS (Optional)
# =============================================================================

# Flask environment (development, production)
FLASK_ENV=development

# Enable Flask debug mode (only for development)
FLASK_DEBUG=True

# =============================================================================
# EMAIL / NOTIFICATION CONFIGURATION
# =============================================================================

# SMTP server settings
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password
MAIL_USE_TLS=True
MAIL_USE_SSL=False

# Sender and admin addresses
MAIL_FROM=no-reply@example.com
ADMIN_EMAIL=admin@example.com

# Optional token for protected admin API endpoint
# Endpoint: POST /api/admin/send-appointment-reminders
# Header: X-Admin-Token: <ADMIN_API_TOKEN>
ADMIN_API_TOKEN=change-this-to-a-strong-random-token